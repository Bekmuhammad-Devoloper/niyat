# Niyat AI Murabbiy - environment configuration
# Bu faylni `.env` deb nusxa ko'chiring va kerakli kalitni qo'ying.
# Faqat bittasi yetarli. Tartib: Gemini > Anthropic > OpenAI

# 1) Google Gemini (TAVSIYA ETILADI — bepul, o'zbek tilini yaxshi biladi)
# https://aistudio.google.com/apikey → Create API key
# Format: AIzaSy...
# Model: gemini-2.0-flash
# Limit: 1500 so'rov/kun BEPUL
GEMINI_API_KEY=

# 2) Anthropic Claude (premium)
# https://console.anthropic.com → API Keys → Create Key
# Format: sk-ant-api03-...
# Model: claude-opus-4-7, prompt caching, adaptive thinking
ANTHROPIC_API_KEY=

# 3) OpenAI (muqobil)
# https://platform.openai.com/api-keys → Create new secret key
# Format: sk-proj-... yoki sk-...
# Model: gpt-4o-mini
OPENAI_API_KEY=
