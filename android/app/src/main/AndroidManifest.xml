<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Niyat MicService — foreground mikrofon service.
             Android 14+ uchun foregroundServiceType="microphone" shart. -->
        <service
            android:name=".MicService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Niyat VoiceReminderService — ovozli reja eslatmasi.
             AlarmManager triggered TTS engine, ilova yopiq bo'lganda ham
             baland ovozda matnni o'qib beradi. mediaPlayback foreground type
             — TTS audio chiqarish uchun. -->
        <service
            android:name=".VoiceReminderService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- AlarmManager broadcast receiver — Android tomonidan ovozli
             eslatma vaqti kelganda chaqiriladi (ilova yopiq bo'lsa ham). -->
        <receiver
            android:name=".VoiceReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Telefon qayta yuklangach BootReceiver service'ni qayta yoqadi. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Telefon ekran vaqti uchun (foydalanuvchi Settings'dan ruxsat beradi) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Mikrofon (24/7 orqa fon eshitish + Coach ovozli xabar) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Joylashuv (namoz vaqtlari + qibla + admin nazorat) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Foydalanuvchi ilovani yopib qoyganda ham joylashuvni kuzatish uchun -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- Foreground service (background-geolocation + MicService) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Niyat MicService — ilova yopiq paytda ham mikrofon eshitishi uchun -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- VoiceReminderService — TTS audio chiqarish (mediaPlayback) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Telefon qayta yuklangach service'ni avtomatik yoqish uchun -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Doze mode / Battery saver'dan ozod bolish uchun -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- WakeLock — CPU service ishlayotgan paytda uxlamasligi uchun -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Watchdog AlarmManager — service kerakli paytda qayta yoqilsin -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Bildirishnomalar (namoz vaqti eslatmalari uchun) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Qibla kompas uchun magnetometer va accelerometer sensorlar.
         required=false: agar telefon'da sensor yo'q bo'lsa ham ilova ishlaydi
         (foydalanuvchi "Qo'lda burish" rejimini ishlatadi). -->
    <uses-feature
        android:name="android.hardware.sensor.compass"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.sensor.accelerometer"
        android:required="false" />
</manifest>
