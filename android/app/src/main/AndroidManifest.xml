<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- MicService va BootReceiver O'CHIRILGAN — orqa fon mikrofoni
             foydalanuvchini ranjituvchi ("yashil nuqta") va ko'pchilik
             telefon'larda crash bo'ladi. Coach ekrandagi mikrofon yetarli. -->
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Telefon ekran vaqti uchun (foydalanuvchi Settings'dan ruxsat beradi) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Mikrofon (Coach ekranida ovozli xabar uchun — runtime'da so'raladi) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Joylashuv (namoz vaqtlari + qibla uchun) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Bildirishnomalar (namoz vaqti eslatmalari uchun) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Qibla kompas uchun magnetometer va accelerometer sensorlar.
         required=false: agar telefon'da sensor yo'q bo'lsa ham ilova ishlaydi
         (foydalanuvchi "Qo'lda burish" rejimini ishlatadi). -->
    <uses-feature
        android:name="android.hardware.sensor.compass"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.sensor.accelerometer"
        android:required="false" />
</manifest>
